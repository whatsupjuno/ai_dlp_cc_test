<?xml version="1.0" encoding="UTF-8"?>
<!--
  Entitlements for the NEFilterDataProvider system extension. The
  `content-filter-provider` value is what lets this process register as a
  socket content filter. Shares the App Group with the containing app.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.developer.networking.networkextension</key>
    <array>
        <string>content-filter-provider</string>
    </array>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.sentinel.dlp</string>
    </array>
</dict>
</plist>
